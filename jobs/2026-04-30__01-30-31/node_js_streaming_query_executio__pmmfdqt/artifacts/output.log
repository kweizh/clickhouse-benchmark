    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_total_memory_merges (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n  'ClickHouse_CustomMetric_TotalMemoryUsedByMerges' AS name,\\n  toFloat64(SUM(memory_usage)) AS value,\\n  'total memory used by all merges from system.merges table' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM\\n    system.merges\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
