    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_dimensional (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n  concat('clickhouse_', system.dimensional_metrics.metric) AS name,\\n  toFloat64(system.dimensional_metrics.value) AS value,\\n  system.dimensional_metrics.description AS help,\\n  mapConcat(map('hostname', hostName(), 'source', 'dimensional'), system.dimensional_metrics.labels) AS labels,\\n  'gauge' AS type\\nFROM system.dimensional_metrics\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
