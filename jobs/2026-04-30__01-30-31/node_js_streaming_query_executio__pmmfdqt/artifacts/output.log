    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_database_replicated_recovery_time (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n  'ClickHouse_CustomMetric_DatabaseReplicatedRecoveryTime' as name,\\n  toFloat64(recovery_time) as value,\\n  'The recovery time of Replicated database DDL worker' as help,\\n  map('hostname', hostName(), 'cluster', cluster, 'shard_num', toString(shard_num)) as labels,\\n  'gauge' as type\\nFROM system.clusters\\nWHERE is_shared_catalog_cluster = false AND is_local = true AND recovery_time IS NOT NULL\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
