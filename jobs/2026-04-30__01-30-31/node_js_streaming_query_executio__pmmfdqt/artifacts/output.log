  {
    "database": "system",
    "name": "_custom_metrics_dictionary_group",
    "uuid": "56b42890-d87e-4a79-a1c9-b7f41318c659",
    "engine": "Dictionary",
    "is_temporary": 0,
    "data_paths": [],
    "metadata_path": "store/105/105c6eb6-ca3a-4f98-b980-1eb0cfbecc1e/_custom_metrics_dictionary_group.sql",
    "metadata_modification_time": "2026-04-30 08:19:48",
    "metadata_version": 0,
    "dependencies_database": [],
    "dependencies_table": [],
    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_group (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                -- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L94\\n-- This is not quite the same as in the original query but it is close enough\\nSELECT\\n  format('ClickHouse_CustomMetric_ActivePartsInSystem{}', initcap(table)) AS name,\\n  toFloat64(value) as value,\\n  format('The number of active parts in system.{}', table) AS help,\\n  map('hostname', host, 'table', format('system.{}', table)) AS labels,\\n  'gauge' AS type\\nFROM\\n(\\n  SELECT\\n    hostName() as host,\\n    table,\\n    count(*) as value\\n  FROM system.parts\\n  WHERE (database = 'system') AND (active = 1)\\n  GROUP BY host, table\\n)\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L125\\nSELECT\\n  'ClickHouse_CustomMetric_StorageSystemTablesS3DiskBytes' AS name,\\n  toFloat64(sum(bytes_on_disk)) as value,\\n  'The amount of bytes stored on disk s3disk in system database' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.parts\\nWHERE database = 'system' AND disk_name='s3disk'\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L134\\nSELECT\\n  'ClickHouse_CustomMetric_StorageSystemTablesLocalDiskBytes' AS name,\\n  toFloat64(sum(bytes_on_disk)) as value,\\n  'The amount of bytes stored on disk default in system database' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.parts\\nWHERE database = 'system' AND disk_name='default'\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L143\\n-- This is trash.\\nSELECT\\n  'ClickHouse_CustomMetric_StorageSystemTablesS3DiskHotPartsBytes' AS name,\\n  toFloat64(sum(bytes_on_disk)) as value,\\n  'The amount of bytes stored on disk s3disk in system database in parts which were touched recently' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.parts\\nWHERE database = 'system' AND disk_name='s3disk' AND (modification_time >= (now() - toIntervalMinute(15)))\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L172\\nSELECT\\n  'ClickHouse_CustomMetric_NumberOfBrokenDetachedParts' AS name,\\n  toFloat64(count()) as value,\\n  'The number of broken detached parts' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.detached_parts\\nWHERE startsWith(system.detached_parts.name, 'broken')\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L181\\nSELECT\\n  'ClickHouse_CustomMetric_NumberOfWarnings' AS name,\\n  toFloat64(count()) as value,\\n  'The number of warnings issued by the server. It usually indicates about possible misconfiguration' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.warnings\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L190\\nSELECT\\n  'ClickHouse_CustomMetric_NumberOfConcurrentBackups' as name,\\n  toFloat64(count()) as value,\\n  'The number of concurrent backups' as help,\\n  map('hostname', host) AS labels,\\n  'gauge' AS type\\nFROM\\n(\\n  SELECT\\n    hostName() as host,\\n    start_time - lagInFrame(start_time) OVER (ORDER BY start_time ASC) AS diff\\n  FROM system.backups\\n  ORDER BY start_time\\n  OFFSET 1\\n)\\nWHERE diff < 5\\nGROUP BY host\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L209\\n-- Useless metric and alert.\\nSELECT\\n  'ClickHouse_CustomMetric_NumberOfLongRunningProcesses' AS name,\\n  toFloat64(count()) as value,\\n  'The number of long-running processes (queries) taking longer than 720 minutes (alert on 5)' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.processes\\nWHERE elapsed >= 60 * 60 * 12\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L219\\nSELECT\\n  'ClickHouse_CustomMetric_AgeOfTheOldestMutation' AS name,\\n  toFloat64(maxIf(dateDiff('second', create_time, now()), is_done = 0)) as value,\\n  'The age of the oldest mutation (in seconds)' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.mutations\\nGROUP BY hostName()\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L229\\n-- get the lost_part_count. The column value shows the total number of lost parts in the corresponding table\\n-- https://github.com/ClickHouse/ClickHouse/issues/47946\\n-- https://github.com/ClickHouse/data-plane-application/issues/3986\\n-- Exclude tables that had to be dropped but remained after Replicated database replica recovery\\nSELECT\\n  'ClickHouse_CustomMetric_LostPartCount' AS name,\\n  toFloat64(sum(lost_part_count)) as value,\\n  'The age of the oldest mutation (in seconds)' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.replicas\\nWHERE NOT (database LIKE '%_broken_replicated_tables' AND total_replicas=1)\\nUNION ALL\\n-- https://github.com/ClickHouse/data-plane-application/blob/b0f4757310a52f0ef905e98091fd094c6b8da4c9/clickhouse-operator/util/spawn/datadog.go#L243\\n-- Total count of \"detached\" tables in Replicated databases after replica recovery\\nSELECT\\n  'ClickHouse_CustomMetric_BrokenTablesCount' AS name,\\n  toFloat64(count()) as value,\\n  'The total number of detached tables in Replicated databases after replica recovery' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.tables\\nWHERE database LIKE '%_broken_replicated_tables' OR database LIKE '%_broken_tables'\\nGROUP BY hostName()\\nUNION ALL\\n-- The number of errors split by error name (or code) since last server restart\\nSELECT\\n  format('ClickHouse_CustomMetric_NumberOfErrors_{}', name) AS name,\\n  toFloat64(value) as value,\\n  -- The usage of errorCodeToName is needed to avoid problems with aliases.\\n  format('The number of {} errors since last server restart',  errorCodeToName(code)) as help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.errors\\nGROUP BY hostName(), name, code, value\\nUNION ALL\\nSELECT\\n    'ClickHouseErrorMetric_ALL' AS name,\\n    toFloat64(sum(value)) AS value,\\n    'The total number of errors on server since the last restart' AS help,\\n    map('hostname', hostName()) AS labels,\\n    'gauge' AS type\\nFROM system.errors\\nGROUP BY hostName()\\nUNION ALL\\n-- The total number of all errors since last server restart\\nSELECT\\n  'ClickHouse_CustomMetric_TotalNumberOfErrors' AS name,\\n  toFloat64(sum(value)) as value,\\n  'The total number of errors on server since the last restart' as help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' AS type\\nFROM system.errors\\nGROUP BY hostName()\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TablesPerDatabase' AS name,\\n  toFloat64(count()) AS value,\\n  'Number of tables per database' AS help,\\n  map('hostname', hostName(), 'database', database) as labels,\\n  'gauge' AS type\\nFROM system.tables\\nGROUP BY database\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TableSizeCompressed_Top10' as name,\\n  toFloat64(total_bytes) as value,\\n  'Compressed table size for largest tables, excluding system tables' as help,\\n  map('hostname', hostName(), 'database', database, 'table', system.tables.name) as labels,\\n  'gauge' as type\\nFROM system.tables\\nWHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\nHAVING value IS NOT NULL\\nORDER BY total_bytes DESC\\nLIMIT 10\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TableSizeCompressed_Other' as name,\\n  toFloat64(sum(total_bytes)) as value,\\n  'Total compressed table size for all tables except top 10, excluding system tables' as help,\\n  map('hostname', hostName()) as labels,\\n  'gauge' as type\\nFROM\\n(\\n  SELECT total_bytes\\n  FROM system.tables\\n  WHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\n  ORDER BY total_bytes DESC\\n  OFFSET 10\\n)\\nHAVING value IS NOT NULL\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TableSizeUncompressed_Top10' as name,\\n  toFloat64(total_bytes_uncompressed) as value,\\n  'Uncompressed table size for largest tables, excluding system tables' as help,\\n  map('hostname', hostName(), 'database', database, 'table', system.tables.name) as labels,\\n  'gauge' as type\\nFROM system.tables\\nWHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA') AND value IS NOT NULL\\nORDER BY total_bytes_uncompressed DESC\\nLIMIT 10\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TableSizeUncompressed_Other' as name,\\n  toFloat64(sum(total_bytes_uncompressed)) as value,\\n  'Total uncompressed table size for all tables except top 10, excluding system tables' as help,\\n  map('hostname', hostName()) as labels,\\n  'gauge' as type\\nFROM\\n(\\n  SELECT total_bytes_uncompressed\\n  FROM system.tables\\n  WHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\n  ORDER BY total_bytes_uncompressed DESC\\n  OFFSET 10\\n)\\nHAVING value IS NOT NULL\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TableEngine' as name,\\n  toFloat64(count()) as value,\\n  'Number of tables per table engine type, excluding system tables' as help,\\n  map('hostname', hostName(), 'engine', engine) as labels,\\n  'gauge' as type\\nFROM system.tables\\nWHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\nGROUP BY engine\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TotalMarks_Top10' as name,\\n  toFloat64(total_marks) as value,\\n  'Marks per table for top 10 tables, excluding system tables' as help,\\n  map('hostname', hostName(), 'database', database, 'table', system.tables.name) as labels,\\n  'gauge' as type\\nFROM system.tables\\nWHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA') AND value IS NOT NULL\\nORDER BY total_marks DESC\\nLIMIT 10\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_TotalMarks_Other' as name,\\n  toFloat64(sum(total_marks)) as value,\\n  'Total number of marks for all tables except top 10, excluding system tables' as help,\\n  map('hostname', hostName()) as labels,\\n  'gauge' as type\\nFROM\\n(\\n  SELECT total_marks\\n  FROM system.tables\\n  WHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\n  ORDER BY total_marks DESC\\n  OFFSET 10\\n)\\nHAVING value IS NOT NULL\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_ActiveParts_Top10' as name,\\n  toFloat64(active_parts) as value,\\n  'Active parts per table for top 10 tables, excluding system tables' as help,\\n  map('hostname', hostName(), 'database', database, 'table', system.tables.name) as labels,\\n  'gauge' as type\\nFROM system.tables\\nWHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA') AND value IS NOT NULL\\nORDER BY active_parts DESC\\nLIMIT 10\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_ActiveParts_Other' as name,\\n  toFloat64(sum(active_parts)) as value,\\n  'Total number of parts for all tables except top 10, excluding system tables' as help,\\n  map('hostname', hostName()) as labels,\\n  'gauge' as type\\nFROM\\n(\\n  SELECT active_parts\\n  FROM system.tables\\n  WHERE database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\n  ORDER BY total_marks DESC\\n  OFFSET 10\\n)\\nHAVING value IS NOT NULL\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesInFlyPerUser' as name,\\n  toFloat64(count()) as value,\\n  'Number of queries running per user at the moment of metric collection' as help,\\n  map('hostname', hostName(), 'user', user),\\n  'gauge' as type\\nFROM system.processes\\nWHERE is_initial_query GROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesFinishedPerUser' as name,\\n  toFloat64(count()) as value,\\n  'Number of queries finished per user' as help,\\n  map('hostname', hostName(), 'user', user),\\n  'gauge' as type\\nFROM system.query_log\\nWHERE is_initial_query AND  event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) AND system.query_log.type NOT IN ('QueryStart') GROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesFailedPerUser' as name,\\n  toFloat64(count()) as value,\\n  'Number of queries running per user at the moment of metric collection' as help,\\n  map('hostname', hostName(), 'user', user),\\n  'gauge' as type\\nFROM system.query_log\\nWHERE is_initial_query AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) AND system.query_log.type NOT IN ('QueryStart', 'QueryFinish') GROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesInFlyDurationSeconds_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets for current duration of running queries, seconds' as help,\\n  map('hostname', hostName(), 'le', if(arrayFirst(x-> elapsed <= x,[0.1, 0.5, 1, 2, 5, 10, 30, 60, 300, 600, 1800, 3600, +Inf]) as le == +Inf, '+Inf', toString(le))) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY le ORDER BY le DESC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesDurationSeconds_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets for duration of queries finished in last minute excluding system queries, seconds' as help,\\n  map('hostname', hostName(), 'le', if(arrayFirst(x-> query_duration_ms <= x * 1000,[0.1, 0.5, 1, 2, 5, 10, 30, 60, 300, 600, 1800, 3600, +Inf]) as le == +Inf, '+Inf', toString(le))) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE is_initial_query AND system.query_log.type NOT IN ('QueryStart') AND user NOT IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal') AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) GROUP BY le ORDER BY le ASC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InternalQueriesDurationSeconds_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets for duration of queries finished in last minute excluding system queries, seconds' as help,\\n  map('hostname', hostName(), 'le', if(arrayFirst(x-> query_duration_ms <= x * 1000,[0.1, 0.5, 1, 2, 5, 10, 30, 60, 300, 600, 1800, 3600, +Inf]) as le == +Inf, '+Inf', toString(le))) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE is_initial_query AND system.query_log.type NOT IN ('QueryStart') AND user IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal') AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) GROUP BY le ORDER BY le ASC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesMemoryUsage_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets with max memory consumption for queries finished in last minute excluding system queries' as help,\\n  map('hostname', hostName(), 'le', arrayFirst((x, y) -> (memory_usage <= x), [((10 * 1024) * 1024, '10MiB'), ((100 * 1024) * 1024, '100MiB'), (((1 * 1024) * 1024) * 1024, '1GiB'), (((10 * 1024) * 1024) * 1024, '10GiB'), (((100 * 1024) * 1024) * 1024, '100GiB'), (100000000000000, '+Inf')]).2 as le) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE is_initial_query AND system.query_log.type NOT IN ('QueryStart') AND user NOT IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal') AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) GROUP BY le ORDER BY le ASC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InternalQueriesMemoryUsage_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets with max memory consumption for queries finished in last minute excluding system queries' as help,\\n  map('hostname', hostName(), 'le', arrayFirst((x, y) -> (memory_usage <= x), [((10 * 1024) * 1024, '10MiB'), ((100 * 1024) * 1024, '100MiB'), (((1 * 1024) * 1024) * 1024, '1GiB'), (((10 * 1024) * 1024) * 1024, '10GiB'), (((100 * 1024) * 1024) * 1024, '100GiB'), (100000000000000, '+Inf')]).2 as le) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE system.query_log.type NOT IN ('QueryStart') AND user IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal') AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) GROUP BY le ORDER BY le ASC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesMemoryUsage_Hist' as name,\\n  toFloat64(count()) as value,\\n  'Histogram with fixed buckets with max memory consumtion for currently running queries ' as help,\\n  map('hostname', hostName(), 'le', arrayFirst((x, y) -> (memory_usage <= x), [((10 * 1024) * 1024, '10MiB'), ((100 * 1024) * 1024, '100MiB'), (((1 * 1024) * 1024) * 1024, '1GiB'), (((10 * 1024) * 1024) * 1024, '10GiB'), (((100 * 1024) * 1024) * 1024, '100GiB'), (100000000000000, '+Inf')]).2 as le) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY le ORDER BY le ASC\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesMemoryUsagePerUser' as name,\\n  sum(if(memory_usage=0, getSetting('max_untracked_memory')::Int32/2, memory_usage::Float64)) as value,\\n  'Memory consumtion for currently running queries per user, bytes. Zero is accounted as half of max_untracked_memory.' as help,\\n  map('hostname', hostName(), 'user', user) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY user UNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesMemoryUsagePerUser' as name,\\n  sum(if(memory_usage=0, getSetting('max_untracked_memory')::Int32/2, memory_usage::Float64)) as value,\\n  'Memory consumtion for currently running queries per user, bytes. Zero is accounted as half of max_untracked_memory.' as help,\\n  map('hostname', hostName(), 'user', user) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  system.query_log.type NOT IN ('QueryStart')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60\\n  AND toStartOfMinute(now())\\nGROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesPerInterface' as name,\\n  toFloat64(count()) as value,\\n  'Currently runing queries per interface' as help,\\n  map('hostname', hostName(), 'interface', map(1, 'tcp_secure',2, 'http_secure',3, 'tcp',4, 'http',5, 'tcp_over_proxy',6, 'http_over_proxy',7, 'mysql',8, 'management_http',9, 'management_tcp')[interface]) as labels,\\n  'gauge' as type\\nFROM system.processes\\nWHERE is_initial_query GROUP BY interface UNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesPerInterface' as name,\\n  toFloat64(count()) as value,\\n  'Currently runing queries per interface' as help,\\n  map('hostname', hostName(), 'interface', map(1, 'tcp_secure',2, 'http_secure',3, 'tcp',4, 'http',5, 'tcp_over_proxy',6, 'http_over_proxy',7, 'mysql',8, 'management_http',9, 'management_tcp')[interface]) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  is_initial_query\\n  AND system.query_log.type NOT IN ('QueryStart')\\n  AND user NOT IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60\\n  AND toStartOfMinute(now())\\nGROUP BY interface\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InternalQueriesPerInterface' as name,\\n  toFloat64(count()) as value,\\n  'Currently runing queries per interface' as help,\\n  map('hostname', hostName(), 'interface', map(1, 'tcp_secure',2, 'http_secure',3, 'tcp',4, 'http',5, 'tcp_over_proxy',6, 'http_over_proxy',7, 'mysql',8, 'management_http',9, 'management_tcp')[interface]) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  is_initial_query\\n  AND system.query_log.type NOT IN ('QueryStart')\\n  AND user IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60\\n  AND toStartOfMinute(now())\\nGROUP BY interface\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesPerClient' as name,\\n  toFloat64(count()) as value,\\n  'Queries per client in last 1 minute interval, excluding internal users' as help,\\n  map('hostname', hostName(), 'client', client_name) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  is_initial_query\\n  AND system.query_log.type NOT IN ('QueryStart')\\n  AND user NOT IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now())\\nGROUP BY client_name\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InternalQueriesPerClient' as name,\\n  toFloat64(count()) as value,\\n  'Queries per client in last 1 minute interval, internal users' as help,\\n  map('hostname', hostName(), 'client', client_name) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  is_initial_query\\n  AND system.query_log.type NOT IN ('QueryStart')\\n  AND user IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now())\\nGROUP BY client_name\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesPerClient' as name,\\n  toFloat64(count()) as value,\\n  'Currently runing queries per client' as help,\\n  map('hostname', hostName(), 'client', client_name) as labels,\\n  'gauge' as type\\nFROM system.query_log\\nWHERE\\n  is_initial_query\\n  AND system.query_log.type NOT IN ('QueryStart') AND user IN ('admin-internal', 'monitoring-internal', 'prometheus-internal', 'backups-internal', 'management-internal', 'sql_console', 'observability-internal') AND event_date >= today() -1 AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now()) GROUP BY client_name UNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesBytesReadPerUser' as name,\\n  toFloat64(sum(read_bytes)) as value,\\n  'Data read by currently running queries per user' as help,\\n  map('hostname', hostName(), 'user', user) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesBytesReadPerUser' as name,\\n toFloat64(sum(read_bytes)) as value,\\n 'Data read by queries per user for queries finished during last minute' as help,\\n map('hostname', hostName(), 'user', user) as labels,\\n 'gauge' as type\\nFROM system.query_log\\nWHERE\\n  system.query_log.type NOT IN ('QueryStart')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now())\\nGROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesBytesWrittenPerUser' as name,\\n  toFloat64(sum(written_bytes)) as value,\\n  'Data written by currently running queries per user' as help,\\n  map('hostname', hostName(), 'user', user) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY user UNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesBytesWrittenPerUser' as name,\\n toFloat64(sum(written_bytes)) as value,\\n 'Data written by queries per user for queries finished during last minute' as help,\\n map('hostname', hostName(), 'user', user) as labels,\\n 'gauge' as type\\nFROM system.query_log\\nWHERE\\n  system.query_log.type NOT IN ('QueryStart')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now())\\nGROUP BY user\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_InFlyQueriesPerKind' as name,\\n  toFloat64(count()) as value,\\n  'Types of running queries' as help,\\n  map('hostname', hostName(), 'query_kind', query_kind) as labels,\\n  'gauge' as type\\nFROM system.processes\\nGROUP BY query_kind UNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_QueriesPerKind' as name,\\n toFloat64(count()) as value,\\n 'Types of queries, excluding internal queries' as help,\\n map('hostname', hostName(), 'query_kind', query_kind) as labels,\\n 'gauge' as type\\nFROM system.query_log\\nWHERE\\n  system.query_log.type NOT IN ('QueryStart')\\n  AND event_date >= today() -1\\n  AND event_time BETWEEN toStartOfMinute(now())-60 AND toStartOfMinute(now())\\nGROUP BY query_kind\\nUNION ALL\\nSELECT\\n  'ClickHouse_NonReplicated_Databases' AS name,\\n  value,\\n  'The number of non replicated databases' AS help,\\n  map('hostname', hostName(), 'engine', engine) AS labels,\\n  'gauge' as type\\n  FROM (\\n    SELECT\\n      toFloat64(count(*)) AS value,\\n      engine\\n    FROM system.databases\\n    WHERE (name NOT IN ('system', 'information_schema', 'INFORMATION_SCHEMA'))\\n    AND (engine != 'Replicated')\\n    GROUP BY hostName(), engine)\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_MergeTreeSystemTables_Total' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of system tables ending in _log%' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.tables\\n  WHERE (system.tables.database = 'system' AND  system.tables.name ILIKE '%_log%')\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_MergeTreeSystemTables_Rolled' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of rolled system tables ending in _log_%' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.tables\\n  WHERE (system.tables.database = 'system' AND  system.tables.name ILIKE '%_log_%')\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_MergeTreeSystemTables_ActiveParts' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of active parts in system tables ending in _log%' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.parts\\n  WHERE (system.parts.database = 'system' AND  system.parts.active = 1 AND system.parts.table ILIKE '%_log%')\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_PlainRewritableSystemTables_Total' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of system tables ending in _log% running on plain_rewritable_disk' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.tables\\n  WHERE (system.tables.database = 'system' AND  system.tables.name ILIKE '%_log%'AND (system.tables.storage_policy = 'plain_rewritable_system_tables' OR storage_policy LIKE '%tmp%'))\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_PlainRewritableSystemTables_Rolled' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of rolled system tables ending in _log_% running on plain_rewritable_disk' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.tables\\n  WHERE (system.tables.database = 'system' AND  system.tables.name ILIKE '%_log_%' AND (system.tables.storage_policy = 'plain_rewritable_system_tables' OR storage_policy LIKE '%tmp%'))\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_PlainRewritableSystemTables_ActiveParts' AS name,\\n  toFloat64(count(*)) AS value,\\n  'The number of active parts in system tables ending in _log% running on plain_rewritable_disk' AS help,\\n  map('hostname', hostName()) AS labels,\\n  'gauge' as type\\n  FROM system.parts\\n  WHERE (system.parts.database = 'system' AND  system.parts.active = 1 AND system.parts.table ILIKE '%_log%' AND (system.parts.disk_name = 'diskPlainRewritableForSystemTables' OR system.parts.disk_name LIKE '%tmp%'))\\nUNION ALL\\nSELECT\\n  'ClickHouse_CustomMetric_DiskStorage' as name,\\n  toFloat64(sum(total_bytes)) as value,\\n  'Total number of bytes of all user tables' as help,\\n  map('hostname', hostName()) as labels,\\n  'gauge' as type\\n  FROM system.tables\\n  WHERE (multiMatchAny(storage_policy, _CAST(['^s3$', '^s3_with_keeper$', '^KeeperMap$', '^__tmp_internal_.*$'], 'Array(String)')) > 0) AND database NOT IN ('system', 'information_schema','INFORMATION_SCHEMA')\\n  HAVING value IS NOT NULL\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 90) LAYOUT(COMPLEX_KEY_HASHED)",
