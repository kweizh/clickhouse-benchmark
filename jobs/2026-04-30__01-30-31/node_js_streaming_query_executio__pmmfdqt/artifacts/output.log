    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_histograms (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n  concat('ClickHouseHistogramMetrics_', system.histogram_metrics.metric) AS name,\\n  toFloat64(system.histogram_metrics.value) AS value,\\n  system.histogram_metrics.description AS help,\\n  mapConcat(map('hostname', hostName()), system.histogram_metrics.labels) AS labels,\\n  'histogram' AS type\\nFROM system.histogram_metrics\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
