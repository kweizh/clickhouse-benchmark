    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_custom_metrics_tables (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n    'ClickHouse_MetricsCollection_CustomMetricsSystemTable' AS name,\\n    toFloat64(1) AS value,\\n    'System table for metrics collection' AS help,\\n    map('hostname', hostName(), 'database', database, 'table', table) AS labels,\\n    'counter' AS type\\nFROM system.tables\\nWHERE database = 'system' AND table like '%custom_metrics%'\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
