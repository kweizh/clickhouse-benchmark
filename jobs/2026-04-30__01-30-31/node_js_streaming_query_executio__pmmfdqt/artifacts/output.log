    "create_table_query": "CREATE DICTIONARY system._custom_metrics_dictionary_failed_mutations (`name` String, `labels_serialized` String, `value` Float64, `help` String, `type` String) PRIMARY KEY name, labels_serialized SOURCE(CLICKHOUSE(QUERY `\\n            SELECT\\n                name,\\n                toJSONString(labels) as labels_serialized,\\n                value,\\n                help,\\n                type\\n            FROM (\\n                SELECT\\n  'ClickHouse_CustomMetric_FailedMutations' as name,\\n  toFloat64(count()) as value,\\n  'The number of failed mutations by error codes' as help,\\n  map('hostname', hostName(), 'error_code_name', latest_fail_error_code_name) as labels,\\n  'gauge' as type\\nFROM system.mutations\\nWHERE latest_fail_error_code_name != ''\\nGROUP BY latest_fail_error_code_name\\n\\n            )\\n        `)) LIFETIME(MIN 0 MAX 60) LAYOUT(COMPLEX_KEY_HASHED)",
